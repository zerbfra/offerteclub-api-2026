PORT=3000
DEFAULT_STORE=it
DEFAULT_LANG=it
SEARCH_DEBUG=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_AMAZON_TTL_HOURS=3

# Amazon CreatorsAPI
AMAZON_CREDENTIAL_ID=
AMAZON_CREDENTIAL_SECRET=
AMAZON_VERSION=2.2

# Partner tag per marketplace Amazon
AMAZON_PARTNER_TAG_IT=offertetech08-21

# PostgreSQL Datafeeds
POSTGRES_DATAFEEDS_URL=postgres://user:password@localhost:5432/datafeeds

# MySQL Telegram stats
MYSQL_URL=mysql://user:password@host:25060/telegram_stats?ssl-mode=REQUIRED

# Firebase Admin (Firestore) — passare UNO dei due:
# - FIREBASE_CREDENTIALS_PATH: path al JSON delle service account credentials (dev locale)
# - FIREBASE_CREDENTIALS_JSON: JSON inline (anche base64) delle credentials (prod, es. DigitalOcean App Platform)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# FIREBASE_CREDENTIALS_JSON=

# DigitalOcean Functions — Yourls click stats (usato da /api/offers/top)
DO_FUNCTIONS_URL=
DO_FUNCTIONS_TOKEN=

# Push notifications (Expo) — fan-out su nuovi `posts` Firestore
# Abilita il listener onSnapshot al boot (impostare a `true` solo nel processo che deve emettere push)
PUSH_LISTENER_ENABLED=false
# Token usato dal Bearer auth della route POST /api/push/test (usa un valore lungo e casuale)
PUSH_ADMIN_TOKEN=
# Opzionale: access token Expo per rate limits più alti / receipts
EXPO_ACCESS_TOKEN=
# Country filtro per il listener (default: it)
PUSH_COUNTRY=it
# TTL della chiave idempotency Redis (default 7 giorni)
PUSH_IDEMPOTENCY_TTL_SECONDS=604800
# Ritardo prima del polling dei receipts (default 15 min)
PUSH_RECEIPT_DELAY_SECONDS=900
# Intervallo del poller receipts (default 60s)
PUSH_RECEIPT_POLL_INTERVAL_SECONDS=60

# DatoCMS — Content Delivery API (GraphQL, sola lettura): slide della home (/api/cms/slides)
# Read-only API token del progetto DatoCMS
DATOCMS_API_TOKEN=
# Endpoint GraphQL (default: https://graphql.datocms.com/)
# DATOCMS_ENDPOINT=https://graphql.datocms.com/
# Cache Redis (secondi) davanti a DatoCMS (default 300)
DATOCMS_CACHE_TTL_SECONDS=300
