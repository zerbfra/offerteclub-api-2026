PORT=3000
DEFAULT_STORE=it
DEFAULT_LANG=it

# Redis
REDIS_URL=redis://localhost:6379
REDIS_AMAZON_TTL_HOURS=3

# Amazon CreatorsAPI
AMAZON_CREDENTIAL_ID=
AMAZON_CREDENTIAL_SECRET=
AMAZON_VERSION=2.2

# Partner tag per marketplace Amazon
AMAZON_PARTNER_TAG_IT=offertetech08-21

# PostgreSQL Datafeeds
POSTGRES_DATAFEEDS_URL=postgres://user:password@localhost:5432/datafeeds

# MySQL Telegram stats
MYSQL_URL=mysql://user:password@host:25060/telegram_stats?ssl-mode=REQUIRED

# Firebase Admin (Firestore) — path al JSON delle service account credentials
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# DigitalOcean Functions — Yourls click stats (usato da /api/offers/top)
DO_FUNCTIONS_URL=
DO_FUNCTIONS_TOKEN=
