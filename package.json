{
  "name": "offerteclub-web-gateway",
  "version": "1.0.0",
  "description": "Gateway HTTP Fastify + Redis per API esterne (Amazon CreatorsAPI)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f redis"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.15.0",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@amzn/creatorsapi-nodejs-sdk": "file:vendor/creatorsapi-nodejs-sdk",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "pg": "^8.19.0"
  }
}
