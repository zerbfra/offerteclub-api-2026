              "raw": "{\n  \"uid\": \"{{uid}}\",\n  \"type\": \"favorite_hit\",\n  \"title\": \"Un tuo preferito è in offerta\",\n  \"body\": \"PlayStation 5 Slim Digital — torniamo a segnalarla a 399€\",\n  \"dealId\": \"test-favorite\"\n}"
            },
            "url": {
