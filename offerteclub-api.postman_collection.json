          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{pushAdminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uid\": \"{{uid}}\",\n  \"type\": \"community_hot\",\n  \"title\": \"Tra le più commentate oggi\",\n  \"body\": \"23 utenti stanno parlando di questa offerta — Lego Star Wars 75355 a 59,90€\",\n  \"dealId\": \"test-community\"\n}"
